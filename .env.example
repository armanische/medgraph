# REQUIRED для работающей формы заявки. SERVER-ONLY, FORBIDDEN IN BROWSER.
# URL CRM, Make, n8n или собственного API, принимающего POST с JSON-заявкой.
CYBERMEDICA_LEADS_WEBHOOK_URL=

# OPTIONAL. SERVER-ONLY, FORBIDDEN IN BROWSER. Bearer-токен webhook.
CYBERMEDICA_LEADS_WEBHOOK_TOKEN=

# OPTIONAL. SERVER-ONLY. Явное разрешение индексации public Production.
# Для Preview оставить пустым. SAFE FOR BROWSER только как поведение robots,
# но значение читается исключительно на сервере.
CYBERMEDICA_ALLOW_INDEXING=

# INTERNAL-ONLY, SERVER-ONLY, FORBIDDEN IN BROWSER.
# Локальный прототип CMS. В production /admin скрыт, если значение не равно 1.
# Не является authentication; при включении обязательна Deployment Protection.
CYBERMEDICA_ENABLE_ADMIN=

# INTERNAL-ONLY, SERVER-ONLY, FORBIDDEN IN BROWSER.
# Внутренние read-only маршруты. В production каждый маршрут скрыт, если
# соответствующее значение не равно 1. Флаги не являются authentication;
# для Preview при включении обязательна Deployment Protection.
CYBERMEDICA_ENABLE_INTERNAL_REVIEW=
CYBERMEDICA_ENABLE_IMPORT_CENTER=
CYBERMEDICA_ENABLE_WAVE2_DASHBOARD=

# REQUIRED для записи review decisions в Production. INTERNAL-ONLY,
# SERVER-ONLY, FORBIDDEN IN BROWSER. Не принимается из client input.
CYBERMEDICA_REVIEWER_ID=

# OPTIONAL, DEVELOPMENT/TEST-ONLY, SERVER-ONLY, FORBIDDEN IN BROWSER.
# По умолчанию false/пусто. Значение 1 разрешает только изолированные fixtures;
# в Production игнорируется.
CYBERMEDICA_ENABLE_REVIEW_FIXTURES=

# OPTIONAL для build, REQUIRED для public product projection.
# SAFE FOR BROWSER по модели Supabase anon key, но текущая реализация читает
# значения только в server-only клиенте. Не использовать service-role key.
# Доступ ограничивается схемой public_api и RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Required by the read-only Cloud Preview repository.
SUPABASE_SERVICE_ROLE_KEY=

# OPTIONAL. Defaults to static. `cloud_preview` is server-only and forbidden in
# Vercel Production; use it only for a protected Preview deployment.
CATALOG_DATA_SOURCE=

# IMPORT-ONLY, SERVER-ONLY, FORBIDDEN IN BROWSER. Не нужны Preview/Production UI.
# Значение none отключает сетевой research provider.
CATALOG_RESEARCH_PROVIDER=

# OPTIONAL, IMPORT-ONLY, SERVER-ONLY, FORBIDDEN IN BROWSER.
# Явные пути к локальным исполняемым файлам; не задавать в Vercel Preview.
CHROME_PATH=
PDFTOTEXT_PATH=
PYTHON_PATH=
